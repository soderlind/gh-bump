	"dependencies": {
		"@actions/core": "^3.0.0",
		"@actions/github": "^9.1.0",
		"@ai-sdk/anthropic": "^3.0.71",
		"@ai-sdk/openai": "^3.0.53",
		"@octokit/rest": "^22.0.1",
		"ai": "^6.0.168",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
